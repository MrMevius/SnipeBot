# --- Core runtime ---
SNIPEBOT_ENV=production
SNIPEBOT_LOG_LEVEL=INFO
SNIPEBOT_DB_URL=sqlite:////data/snipebot.db
# Production recommendation (PostgreSQL/TimescaleDB):
# SNIPEBOT_DB_URL=postgresql+psycopg://snipebot:snipebot@db:5432/snipebot

# --- Worker scheduling ---
SNIPEBOT_WORKER_INTERVAL_SECONDS=60
SNIPEBOT_CHECK_INTERVAL_SECONDS=1800
SNIPEBOT_RETRY_INTERVAL_SECONDS=300
SNIPEBOT_WORKER_BATCH_SIZE=25

# --- Optional scraping fallback ---
SNIPEBOT_PLAYWRIGHT_FALLBACK_ENABLED=false
SNIPEBOT_PLAYWRIGHT_FALLBACK_ADAPTERS=

# --- Optional notifications ---
SNIPEBOT_NOTIFICATIONS_ENABLED=false
SNIPEBOT_TELEGRAM_ENABLED=false
SNIPEBOT_TELEGRAM_BOT_TOKEN=__set-in-.env-or-runtime-secret__
SNIPEBOT_TELEGRAM_CHAT_ID=

# --- Host bind + ports (Docker Compose) ---
# Keep API bound to localhost unless an external proxy must reach it directly.
SNIPEBOT_API_BIND=127.0.0.1
SNIPEBOT_API_PORT=8001
SNIPEBOT_FRONTEND_BIND=0.0.0.0
SNIPEBOT_FRONTEND_PORT=5173

# --- Frontend build-time API base URL ---
# Keep `/api` for reverse-proxy-friendly deployments.
VITE_API_BASE_URL=/api
